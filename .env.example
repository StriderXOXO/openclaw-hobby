# ============================================
# openclaw-hobby 环境变量配置
# ============================================
# 基础运行无需任何凭证！默认使用 SQLite 本地存储。
# 只需取消注释你需要的部分。
#
# cp .env.example .env

# ============================================
# [默认] 存储后端
# ============================================
# 默认 SQLite，无需设置。改为飞书需取消下方注释。
# STORAGE_BACKEND=sqlite

# ============================================
# [可选] LLM 智能分析
# ============================================
# 用于 triage 内容分析（摘要/亮点/主题标签）。
# 支持任何兼容 Anthropic Messages API 的提供商。
# 不设置也能采集，只是没有 LLM 分析。
#
# LLM_ENDPOINT=https://api.anthropic.com/v1/messages
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# ============================================
# [可选] 更多数据源
# ============================================
# Podcast 只需 RSS，零 API Key。下面是额外数据源的 Key。
#
# Twitter API (twitterapi.io, 付费)
# TWITTER_API_KEY=
#
# Whisper API（播客音频转录，需 GPU 机器）
# WHISPER_ENDPOINT=http://your-gpu-server:9876
# WHISPER_TOKEN=
#
# YouTube 字幕代理（VPS IP 被封时使用）
# YOUTUBE_TRANSCRIPT_PROXY_URL=
# YOUTUBE_TRANSCRIPT_PROXY_TOKEN=

# ============================================
# [可选] 飞书知识库 + 推送
# ============================================
# 切换到飞书存储：取消注释并填入凭证。
# 需在 https://open.feishu.cn 创建企业自建应用。
# 权限: bitable:app, im:message, drive:file
#
# STORAGE_BACKEND=feishu
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_APP_TOKEN=
# FEISHU_CHAT_ID=
# PODCAST_TABLE_ID=
# YOUTUBE_TABLE_ID=
# TWITTER_TABLE_ID=

# ============================================
# [可选] Watchdog 远程服务重启
# ============================================
# 当 Whisper API 健康检查失败时，watchdog 可自动 SSH 重启。
# 推荐使用 SSH key 认证（更安全）：
# REMOTE_HOST=100.79.241.95
# REMOTE_USER=strider
# SSH_KEY_PATH=~/.ssh/whisper-restart
#
# 或使用密码（通过 sshpass -e 传递，不暴露在命令行）：
# REMOTE_PASS=your-password
